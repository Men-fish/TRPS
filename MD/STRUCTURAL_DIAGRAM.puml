@startuml Structural_Diagram
!theme plain
skinparam linetype ortho
skinparam componentStyle rectangle
skinparam packageStyle rectangle

' ============================================
' СТРУКТУРНАЯ СХЕМА ПРОГРАММНОГО ПРОДУКТА
' Веб-агрегатор спортивных тренеров (TRPS2)
' ============================================

package "Внешний уровень" {
    [HTTP Client] as Client
    [SQLite Database] as DB
}

package "Flask Application" {
    [app.py] as App
    [config.py] as Config
    
    package "app/__init__.py" {
        [Application Factory] as Init
    }
    
    package "API Blueprints" {
        [auth.py] as AuthBP
        [trainers.py] as TrainersBP
        [records.py] as RecordsBP
        [reviews.py] as ReviewsBP
        [schedules.py] as SchedulesBP
    }
    
    package "Core Modules" {
        [models.py] as Models
        [database.py] as Database
        [validators.py] as Validators
        [csrf.py] as CSRF
        [errors.py] as Errors
    }
}

' Внешние связи
Client <--> App
Database --> DB

' Инициализация приложения
App --> Config
App --> Init
Init --> Database
Init --> CSRF
Init --> Errors
Init --> AuthBP
Init --> TrainersBP
Init --> RecordsBP
Init --> ReviewsBP
Init --> SchedulesBP

' Зависимости Blueprints от Core Modules
AuthBP --> Models
AuthBP --> Validators
AuthBP --> CSRF

TrainersBP --> Models
TrainersBP --> Validators

RecordsBP --> Models
RecordsBP --> Validators
RecordsBP --> CSRF
RecordsBP --> Database

ReviewsBP --> Models
ReviewsBP --> Validators
ReviewsBP --> CSRF

SchedulesBP --> Models
SchedulesBP --> Validators
SchedulesBP --> CSRF

' Зависимости Models от Database и Validators
Models --> Database
Models --> Validators

' Зависимости Database
Database --> DB

@enduml

