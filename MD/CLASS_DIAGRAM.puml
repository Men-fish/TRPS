@startuml Class_Diagram
!theme plain
skinparam classAttributeIconSize 0
skinparam linetype ortho

' ============================================
' ДИАГРАММА КЛАССОВ МОДУЛЕЙ
' Веб-агрегатор спортивных тренеров (TRPS2)
' ============================================

package "Модели данных" {
    class User {
        - id: Integer
        - full_name: String
        - email: String
        - password_hash: String
        - passport_data: String
        - created_at: Timestamp
        --
        + {static} create(full_name, email, password, passport_data): dict
        + {static} get_by_id(user_id): dict
        + {static} get_by_email(email): dict
        + {static} verify_password(user, password): bool
    }
    
    class Trainer {
        - id: Integer
        - full_name: String
        - specialization: String
        - description: String
        - address: String
        - gym_name: String
        - created_at: Timestamp
        --
        + {static} create(full_name, specialization, description, address, gym_name): dict
        + {static} get_by_id(trainer_id): dict
        + {static} get_all(specialization, search): list
        + {static} exists(trainer_id): bool
    }
    
    class Record {
        - id: Integer
        - user_id: Integer
        - trainer_id: Integer
        - datetime: String
        - duration: Integer
        - status: String
        - created_at: Timestamp
        --
        + {static} STATUS_PENDING: String
        + {static} STATUS_CONFIRMED: String
        + {static} STATUS_CANCELLED: String
        + {static} STATUS_COMPLETED: String
        + {static} create(user_id, trainer_id, datetime_str, duration, status): dict
        + {static} get_by_id(record_id): dict
        + {static} get_by_user(user_id, status): list
        + {static} get_by_trainer(trainer_id, status): list
        + {static} update(record_id, datetime_str, duration, status): dict
        + {static} cancel(record_id): dict
        + {static} belongs_to_user(record_id, user_id): bool
        + {static} exists_conflicting_record(trainer_id, datetime_str, duration, exclude_record_id): bool
    }
    
    class Review {
        - id: Integer
        - user_id: Integer
        - trainer_id: Integer
        - text: String
        - rating: Integer
        - created_at: Timestamp
        - updated_at: Timestamp
        --
        + {static} create(user_id, trainer_id, text, rating): dict
        + {static} get_by_id(review_id): dict
        + {static} get_by_trainer(trainer_id): list
        + {static} get_by_user_and_trainer(user_id, trainer_id): dict
        + {static} update(review_id, text, rating): dict
        + {static} belongs_to_user(review_id, user_id): bool
    }
    
    class Schedule {
        - id: Integer
        - trainer_id: Integer
        - day_of_week: Integer
        - start_time: String
        - end_time: String
        - is_active: Integer
        - created_at: Timestamp
        - updated_at: Timestamp
        --
        + {static} DAYS_OF_WEEK: dict
        + {static} create(trainer_id, day_of_week, start_time, end_time, is_active): dict
        + {static} get_by_id(schedule_id): dict
        + {static} get_by_trainer(trainer_id): list
        + {static} get_by_trainer_and_day(trainer_id, day_of_week): dict
        + {static} update(schedule_id, start_time, end_time, is_active): dict
        + {static} delete(schedule_id): bool
        + {static} exists(schedule_id): bool
        + {static} is_working_time(trainer_id, datetime_obj): tuple
    }
}

package "Валидация" {
    class Validators {
        + {static} validate_email(email): tuple
        + {static} validate_password(password): tuple
        + {static} validate_full_name(full_name): tuple
        + {static} validate_passport_data(passport_data): tuple
        + {static} validate_datetime(datetime_str): tuple
        + {static} validate_rating(rating): tuple
        + {static} validate_address(address): tuple
        + {static} validate_gym_name(gym_name): tuple
        + {static} validate_required_fields(data, required_fields): tuple
        + {static} validate_time(time_str): tuple
        + {static} validate_day_of_week(day_of_week): tuple
        + {static} validate_duration(duration): tuple
    }
}

package "База данных" {
    class Database {
        + {static} get_db(): Connection
        + {static} close_db(e): void
        + {static} init_db(): void
        + {static} init_app(app): void
    }
}

package "Безопасность" {
    class CSRFProtection {
        + {static} init_csrf(app): void
        + {static} get_csrf_token(): String
        + {static} csrf_required(f): decorator
    }
}

package "Обработка ошибок" {
    class ErrorHandlers {
        + {static} register_error_handlers(app): void
    }
}

package "API Blueprints" {
    class AuthBlueprint {
        + require_auth(f): decorator
        + register(): Response
        + login(): Response
        + logout(): Response
        + get_current_user(): Response
    }
    
    class TrainersBlueprint {
        + get_trainers(): Response
        + get_trainer(trainer_id): Response
    }
    
    class RecordsBlueprint {
        + get_records(): Response
        + create_record(): Response
        + update_record(record_id): Response
        + delete_record(record_id): Response
        + get_user_records(user_id): Response
        + get_trainer_records(trainer_id): Response
    }
    
    class ReviewsBlueprint {
        + get_reviews(trainer_id): Response
        + create_review(): Response
        + update_review(review_id): Response
    }
    
    class SchedulesBlueprint {
        + get_schedules(trainer_id): Response
        + create_schedule(): Response
        + update_schedule(schedule_id): Response
        + delete_schedule(schedule_id): Response
    }
}

' Композиция (сильная связь - часть не может существовать без целого)
User *-- Record : "создает"
Trainer *-- Record : "имеет записи"
User *-- Review : "пишет"
Trainer *-- Review : "получает"

' Агрегация (слабая связь - часть может существовать отдельно)
Trainer o-- Schedule : "имеет расписание"

' Зависимость (использование)
Trainer ..> Validators : "использует для валидации"
Record ..> Database : "использует"
Record ..> Schedule : "использует для проверки рабочего времени"
Review ..> Database : "использует"
Schedule ..> Database : "использует"
User ..> Database : "использует"

' Зависимость Blueprints от моделей и валидаторов
AuthBlueprint ..> User : "использует"
AuthBlueprint ..> Validators : "использует"
AuthBlueprint ..> CSRFProtection : "использует"

TrainersBlueprint ..> Trainer : "использует"
TrainersBlueprint ..> Review : "использует"

RecordsBlueprint ..> Record : "использует"
RecordsBlueprint ..> Trainer : "использует"
RecordsBlueprint ..> Schedule : "использует"
RecordsBlueprint ..> User : "использует"
RecordsBlueprint ..> Validators : "использует"
RecordsBlueprint ..> CSRFProtection : "использует"

ReviewsBlueprint ..> Review : "использует"
ReviewsBlueprint ..> Trainer : "использует"
ReviewsBlueprint ..> Validators : "использует"
ReviewsBlueprint ..> CSRFProtection : "использует"

SchedulesBlueprint ..> Schedule : "использует"
SchedulesBlueprint ..> Trainer : "использует"
SchedulesBlueprint ..> Validators : "использует"
SchedulesBlueprint ..> CSRFProtection : "использует"

' Зависимость от Database
Database <.. User
Database <.. Trainer
Database <.. Record
Database <.. Review
Database <.. Schedule

' Зависимость от ErrorHandlers
ErrorHandlers <.. AuthBlueprint
ErrorHandlers <.. TrainersBlueprint
ErrorHandlers <.. RecordsBlueprint
ErrorHandlers <.. ReviewsBlueprint
ErrorHandlers <.. SchedulesBlueprint

@enduml

