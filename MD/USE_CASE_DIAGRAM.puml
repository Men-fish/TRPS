@startuml Use_Case_Diagram
!theme plain
skinparam usecase {
    BackgroundColor #E8F4F8
    BorderColor #2E86AB
    FontSize 11
}
skinparam actor {
    BackgroundColor #FFFFFF
    BorderColor #2E86AB
}

' ============================================
' ДИАГРАММА ВАРИАНТОВ ИСПОЛЬЗОВАНИЯ
' Веб-агрегатор спортивных тренеров (TRPS2)
' ============================================

left to right direction

actor "Клиентская часть" as Client

rectangle "Веб-агрегатор спортивных тренеров" {
    
    package "Аутентификация" {
        usecase "Регистрация" as UC1
        usecase "Вход в систему" as UC2
        usecase "Выход из системы" as UC3
        usecase "Просмотр профиля" as UC4
        usecase "Получение CSRF токена" as UC5
    }
    
    package "Работа с тренерами" {
        usecase "Просмотр списка тренеров" as UC6
        usecase "Поиск по специализации" as UC7
        usecase "Просмотр деталей тренера" as UC8
        usecase "Просмотр отзывов о тренере" as UC9
    }
    
    package "Управление записями" {
        usecase "Просмотр своих записей" as UC10
        usecase "Создание записи" as UC11
        usecase "Изменение записи" as UC12
        usecase "Отмена записи" as UC13
    }
    
    package "Управление отзывами" {
        usecase "Создание отзыва" as UC14
        usecase "Редактирование отзыва" as UC15
    }
}

' Связи для Клиентской части
Client --> UC1
Client --> UC2
Client --> UC3
Client --> UC4
Client --> UC5
Client --> UC6
Client --> UC7
Client --> UC8
Client --> UC9
Client --> UC10
Client --> UC11
Client --> UC12
Client --> UC13
Client --> UC14
Client --> UC15

' Расширения и включения
UC2 ..> UC5 : <<include>>
UC11 ..> UC5 : <<include>>
UC12 ..> UC5 : <<include>>
UC13 ..> UC5 : <<include>>
UC14 ..> UC5 : <<include>>
UC15 ..> UC5 : <<include>>

UC8 ..> UC9 : <<include>>

@enduml

